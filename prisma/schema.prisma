enum VendorPriceImportStatus {
  PROCESSING
  READY
  FAILED
  COMMITTED
  DISCARDED
}

enum VendorPriceImportSourceType {
  UPLOAD
  GMAIL
}

enum VendorPriceImportLineMatchStatus {
  MATCHED
  CONFLICT_IN_FILE
  UNMATCHED
  NO_COST_CHANGE
  EXCLUDED
  MATCHED_AMBIGUOUS
  DUPLICATE_COLLAPSED
}

model VendorPriceProfile {
  id              String   @id @default(cuid())
  vendorKey       String   @unique @map("vendor_key")
  displayName     String   @map("display_name")
  matchVendorKey  String   @map("match_vendor_key")
  parserType      String   @map("parser_type")
  parserConfig    Json     @map("parser_config")
  gmailConfig     Json?    @map("gmail_config")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  imports VendorPriceImport[]

  @@map("vendor_price_profiles")
}

model VendorPriceImport {
  id                String                      @id @default(cuid())
  status            VendorPriceImportStatus     @default(PROCESSING)
  vendorKey         String                      @map("vendor_key")
  sourceType        VendorPriceImportSourceType @default(UPLOAD) @map("source_type")
  sourceFileName    String                      @map("source_file_name")
  sourceContentType String?                     @map("source_content_type")
  sourceFileSize    Int                         @default(0) @map("source_file_size")
  sourceFileHash    String?                     @map("source_file_hash")
  sourceFileBytes   Bytes?                      @map("source_file_bytes")
  summary           Json?                       @map("summary")
  reviewSnapshot    Json?                       @map("review_snapshot")
  gmailMessageId    String?                     @map("gmail_message_id")
  gmailAttachmentId String?                     @map("gmail_attachment_id")
  createdBy         String                      @map("created_by")
  committedBy       String?                     @map("committed_by")
  committedAt       DateTime?                   @map("committed_at")
  commitSummary     Json?                       @map("commit_summary")
  errorMessage      String?                     @db.Text @map("error_message")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")

  profile   VendorPriceProfile @relation(fields: [vendorKey], references: [vendorKey])
  creator   User               @relation("VendorPriceImportCreatedBy", fields: [createdBy], references: [id])
  committer User?              @relation("VendorPriceImportCommittedBy", fields: [committedBy], references: [id])
  lines     VendorPriceImportLine[]

  @@index([status])
  @@index([vendorKey])
  @@index([createdBy])
  @@index([createdAt])
  @@index([gmailMessageId, gmailAttachmentId])
  @@map("vendor_price_imports")
}

model VendorPriceImportLine {
  id                    String                         @id @default(cuid())
  importId              String                         @map("import_id")
  rowIndex              Int                            @map("row_index")
  vendorPartIdRaw       String?                        @map("vendor_part_id_raw")
  vendorPartIdNormalized String                        @map("vendor_part_id_normalized")
  descriptionFromFile   String?                        @db.Text @map("description_from_file")
  uomFromFile           String?                        @map("uom_from_file")
  proposedCost          Decimal                        @map("proposed_cost") @db.Decimal(10, 2)
  matchStatus           VendorPriceImportLineMatchStatus @map("match_status")
  partId                String?                        @map("part_id")
  costBefore            Decimal?                       @map("cost_before") @db.Decimal(10, 2)
  costAfter             Decimal?                       @map("cost_after") @db.Decimal(10, 2)
  percentChange         Decimal?                       @map("percent_change") @db.Decimal(10, 4)
  conflictGroupId       String?                        @map("conflict_group_id")
  selected              Boolean                        @default(false)
  createdAt             DateTime                       @default(now()) @map("created_at")
  updatedAt             DateTime                       @updatedAt @map("updated_at")

  import VendorPriceImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  part   Part?              @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([importId])
  @@index([importId, matchStatus])
  @@index([importId, conflictGroupId])
  @@index([partId])
  @@map("vendor_price_import_lines")
}
