model JobImport {
  id                  String          @id @default(cuid())
  status              JobImportStatus @default(PROCESSING)
  mode                JobImportMode   @default(NEW_JOB_IMPORT)
  /// full | header_stub — set at parse time: header_stub when TF picksheet layout has no deterministic material rows
  importIntent        String          @default("full") @map("import_intent")
  sourceFileName      String          @map("source_file_name")
  sourceContentType   String?         @map("source_content_type")
  sourceFileSize      Int             @default(0) @map("source_file_size")
  /// pdf | hvuf — selects which parser parseJobImport() runs; set once at draft creation
  sourceFormat        String          @default("pdf") @map("source_format")
  sourceStorageMode   String          @default("DATABASE") @map("source_storage_mode")
  sourceStorageKey    String          @map("source_storage_key")
  sourceFileBytes     Bytes?          @map("source_file_bytes")
  rawText             String?         @db.Text @map("raw_text")
  ocrMetadata         Json?           @map("ocr_metadata")
  parsedSnapshot      Json?           @map("parsed_snapshot")
  reviewSnapshot      Json?           @map("review_snapshot")
  draftState          Json?           @map("draft_state")
  warningSummary      Json?           @map("warning_summary")
  duplicateSnapshot   Json?           @map("duplicate_snapshot")
  parseVersion        String          @default("job-import-v1") @map("parse_version")
  createdBy           String          @map("created_by")
  targetJobNumber     String?         @map("target_job_number")
  targetListNumber    String?         @map("target_list_number")
  targetJobName       String?         @map("target_job_name")
  /// Deterministically parsed from the source file at parse time (currently
  /// only populated for sourceFormat='hvuf') - used to detect re-uploads of
  /// the same HydraTec export (same job/list/generation date) so the
  /// watcher doesn't create a duplicate draft for an unchanged pick sheet.
  parsedJobNumber      String?         @map("parsed_job_number")
  parsedListNumber     String?         @map("parsed_list_number")
  parsedStocklistDate  String?         @map("parsed_stocklist_date")
  committedBy         String?         @map("committed_by")
  committedAt         DateTime?       @map("committed_at")
  committedJobNumber  String?         @map("committed_job_number")
  committedListNumber String?         @map("committed_list_number")
  commitSummary       Json?           @map("commit_summary")
  errorMessage        String?         @db.Text @map("error_message")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  draftAttachments JobImportDraftAttachment[]

  @@index([status])
  @@index([createdBy])
  @@index([mode, targetJobNumber, targetListNumber, createdAt])
  @@index([committedJobNumber, committedListNumber])
  @@index([createdAt])
  @@index([parsedJobNumber, parsedListNumber, parsedStocklistDate])
  @@map("job_imports")
}

model JobImportDraftAttachment {
  id              String   @id @default(cuid())
  jobImportId     String   @map("job_import_id")
  r2Key           String   @unique @map("r2_key")
  contentType     String   @map("content_type")
  sizeBytes       Int      @map("size_bytes")
  width           Int?
  height          Int?
  fileName        String?  @map("file_name")
  uploadedByEmail String?  @map("uploaded_by_email")
  createdAt       DateTime @default(now()) @map("created_at")

  jobImport JobImport @relation(fields: [jobImportId], references: [id], onDelete: Cascade)

  @@index([jobImportId])
  @@index([createdAt])
  @@map("job_import_draft_attachments")
}

/// A named, revocable API key for a local HydraTec watcher script
/// (lib/hydraTecWatcherAuth.ts). One per machine/location; the raw secret is
/// never persisted, only its bcrypt hash.
model HydraTecWatcherKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  createdBy  String    @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime? @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")

  @@index([keyPrefix])
  @@map("hydratec_watcher_keys")
}

model StandaloneEstimate {
  id            String   @id @default(cuid())
  title         String
  projectName   String?  @map("project_name")
  projectNumber String?  @map("project_number")
  locationLine1 String?  @map("location_line_1")
  locationLine2 String?  @map("location_line_2")
