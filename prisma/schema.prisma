  label         String
  normalizedKey String   @map("normalized_key")
  isActive      Boolean  @default(true) @map("is_active")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([category, normalizedKey], map: "estimate_lookup_category_key")
  @@index([category, isActive], map: "estimate_lookup_category_active_idx")
  @@map("estimate_lookup_options")
}

model StandaloneEstimateVariant {
  id              String   @id @default(cuid())
  estimateId      String   @map("estimate_id")
  templateKey     String   @default("system-1") @map("template_key")
  templateVersion String   @default("system-1-v1") @map("template_version")
  variantKey      String   @default("base") @map("variant_key")
  variantLabel    String?  @map("variant_label")
  variantStatus   String   @default("draft") @map("variant_status")
  data            Json
  subtotal        Decimal? @db.Decimal(12, 2)
  totalCost       Decimal? @db.Decimal(12, 2) @map("total_cost")
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  estimate  StandaloneEstimate           @relation(fields: [estimateId], references: [id], onDelete: Cascade, map: "se_variants_estimate_id_fkey")

  @@unique([estimateId, templateKey, variantKey], map: "se_variants_est_tpl_variant_key")
  @@index([estimateId], map: "se_variants_estimate_id_idx")
  @@index([estimateId, templateKey, variantKey], map: "se_variants_est_tpl_variant_idx")
  @@index([updatedAt], map: "se_variants_updated_at_idx")
  @@map("standalone_estimate_variants")
}

