{
  "name": "northops-fire-protection-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:win": "scripts\\dev.cmd",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:repair-inventory-actors": "tsx scripts/repair-inventory-movement-actors.ts",
    "db:push": "tsx scripts/repair-inventory-movement-actors.ts && prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate deploy",
    "db:baseline": "tsx scripts/baseline-migrations-fast.ts",
    "db:seed-permissions": "tsx scripts/seed-role-permissions.ts",
    "test:job-import": "tsx scripts/test-job-import-reliability.ts",
    "test:job-import-chunks": "tsx scripts/test-job-import-chunks.ts",
    "test:job-import-header-stub": "tsx scripts/test-job-import-header-stub-gates.ts",
    "test:hydratec-import": "tsx scripts/test-hydratec-parser.ts",
    "check:inventory-writes": "tsx scripts/inventory-write-guard.ts",
    "check:part-cost-writes": "tsx scripts/part-cost-write-guard.ts",
    "check:part-info-writes": "tsx scripts/part-info-write-guard.ts",
    "test:vendor-price": "tsc -p scripts/tsconfig.test.json && node scripts/run-vendor-price-tests.cjs",
    "test:permissions": "tsx scripts/test-permission-defaults.ts && tsx scripts/test-permission-resolution.ts && tsx scripts/test-user-permission-scoping.ts && tsx scripts/test-job-permission-scoping.ts",
    "db:import-parts": "tsx scripts/import-parts.ts",
    "db:migrate-delivery": "tsx scripts/migrate-delivery-data.ts",
    "auth:setup": "./scripts/setup-auth.sh",
    "postinstall": "prisma generate"
