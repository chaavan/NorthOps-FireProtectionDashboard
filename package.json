    "@react-pdf/renderer": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/xlsx": "^0.0.35",
    "@vercel/functions": "^2.2.13",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "googleapis": "^173.0.0",
    "hyperformula": "^3.2.0",
    "lucide-react": "^1.21.0",
    "mapbox-gl": "^3.24.0",
    "next": "^16.2.7",
    "next-auth": "^4.24.14",
